# Default: Textdateien → LF im Repo
* text=auto eol=lf

# Windows-spezifische Dateien
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell-Skripte (wichtig für WSL/Docker/CI)
*.sh text eol=lf

# Explizit für Flutter/Dart Code
*.dart text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
